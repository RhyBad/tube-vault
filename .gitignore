# --- v1 (Python) leftovers on developer machines ---
# The Python leg was removed at the P11 cutover; a local .venv may survive
# (it carries the yt-dlp+deno pair the optional TUBEVAULT_SMOKE run can use).
.venv/
venv/
__pycache__/

# --- Node / TypeScript monorepo ---
node_modules/
dist/
build/
coverage/
.pnpm-store/
*.tsbuildinfo
# NOTE: pnpm-lock.yaml IS committed (reproducible builds) — do not ignore it.

# --- IntelliJ / JetBrains IDEs ---
.idea/
.idea_modules/
*.iml
*.iws
out/

# --- VS Code ---
.vscode/

# --- OS noise ---
.DS_Store
Thumbs.db

# --- TubeVault runtime data & SECRETS (never commit) ---
/data/
/data-v2/
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
*.sqlite3-journal
/secrets/
*.key
*.pem
cookies.txt
*.cookies.txt
.env
.env.*
!.env.example

# --- Local scratch / throwaway notes (never commit) ---
/tmp/
