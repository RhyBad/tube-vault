# .gitignore — governs what THIS mirror repo tracks.
# NOTE: distinct from .publishignore.example, which governs what the upstream
# publish step is allowed to SNAPSHOT into this repo (see scripts/publish-from-upstream.sh).

# ---- Dependencies ----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Build / compiled output ----
dist/
build/
out/
lib/
.next/
.nuxt/
.turbo/
*.tsbuildinfo

# ---- Test / coverage ----
coverage/
.nyc_output/
*.lcov

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Env / secrets (keep the tracked example) ----
.env
.env.*
!.env.example

# ---- IDE / editor ----
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# ---- OS cruft ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Docker / local runtime overrides (tracked example compose stays) ----
docker-compose.override.yml
docker-compose.override.yaml
*.pid

# ---- Misc caches / scratch ----
.cache/
tmp/
