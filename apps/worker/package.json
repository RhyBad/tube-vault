{
  "name": "@tubevault/worker",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS standalone worker: WORKER_ROLE=archive|live switch, Job-row CAS recorder, Redis job:control subscriber, boot reconciler, BullMQ enumerate/download/verify consumers (archive role). Live consumers arrive in P10.",
