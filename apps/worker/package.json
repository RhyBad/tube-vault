  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@tubevault/core": "workspace:*",
    "@tubevault/db": "workspace:*",
    "@tubevault/engine": "workspace:*",
    "@tubevault/notify": "workspace:*",
    "@tubevault/storage": "workspace:*",
    "@tubevault/types": "workspace:*",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  }
}
