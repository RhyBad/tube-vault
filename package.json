{
  "name": "tubevault",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted web dashboard to archive, verify and preserve YouTube channels (videos + live streams).",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "pg": "^8.13.1",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "testcontainers": "^10.16.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.4"
  }
}
