# TubeVault deployment config — copy to `.env` (docker compose auto-loads it).
# `.env` holds secrets; it is gitignored. NEVER commit your real .env.

# --- REQUIRED (compose fails fast if any is unset) ------------------------------

# An Argon2 hash of your dashboard password. Generate it without putting the
# password on disk or in shell history (reads stdin; needs the api image built).
# The dummy env prefix matters: compose interpolates the WHOLE compose file for
# EVERY command (even `run --no-deps` and `build`), and the `:?` guards refuse
# while this very value is still empty — chicken-and-egg without the dummies:
#   read -rs pw; printf '%s' "$pw" | TUBEVAULT_ACCESS_SECRET_HASH=x \
#     TUBEVAULT_SESSION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx POSTGRES_PASSWORD=x \
#     docker compose run --rm --no-deps -T \
#     --entrypoint node api -e "let s='';process.stdin.on('data',d=>s+=d).on('end',async()=>console.log(await require('@node-rs/argon2').hash(s)))" \
#     | sed 's/\$/\$\$/g'; unset pw
# GOTCHA: docker compose INTERPOLATES $variables inside .env values, and an
# argon2 hash is full of $ segments ($argon2id$v=19$m=...) — every $ in the
# hash MUST be written as $$ here (the sed above does it) or the api receives
# a silently mangled hash and every login 401s.
TUBEVAULT_ACCESS_SECRET_HASH=

# A random key (>= 32 chars) that signs the session cookie. Generate one:
#   openssl rand -hex 32
TUBEVAULT_SESSION_KEY=

# Postgres password (the db is not host-published, but treat it like a secret):
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# --- STORAGE PATHS (host bind mounts) -------------------------------------------
# WHERE TubeVault keeps data on the host. Each defaults (in docker-compose.yml)
# to a sibling under the archive dir; override to relocate WITHOUT touching the
# rest. The container-internal layout never changes, so this is non-breaking:
# leave them unset and an existing deployment keeps its data on the next up -d.
#
# The media VAULT — usually the only one you relocate. Point it at a NAS / big
# disk. Download + live-capture staging lives inside the vault (atomic rename),
# so it moves with the media. To migrate: stop the stack, rsync the data to the
# new path, set this, `up -d`. (Default in docker-compose.yml is ./data/media.)
# TUBEVAULT_MEDIA_DIR=/srv/tubevault/media
#
# Postgres + Redis data. Keep these on LOCAL disk — never a NAS/NFS share
# (Postgres WAL fsync and Redis AOF corrupt/lock badly over NFS).
# TUBEVAULT_DB_DIR=/srv/tubevault/db
# TUBEVAULT_REDIS_DIR=/srv/tubevault/redis

# --- OPTIONAL -------------------------------------------------------------------

# Set to 1 ONLY for plain-http LAN / Tailscale access (no HTTPS in front of the
# web entrypoint :8091). Never on a public host.
# TUBEVAULT_INSECURE_COOKIES=1

# Postgres identity (defaults shown; DATABASE_URL is derived in compose).
# POSTGRES_USER=tubevault
# POSTGRES_DB=tubevault

# Deadline (ms) for the synchronous yt-dlp extraction behind channel-register /
# add-url requests. Empty = 5 minutes.
# TUBEVAULT_SYNC_EXTRACT_TIMEOUT_MS=300000

# yt-dlp youtube player_client override. RECOMMENDED: leave unset — yt-dlp's maintained default
# (android_vr,web_safari) serves full quality cookieless WITHOUT a PO token. Only pin a client if
# you must, and prefer "android_vr" over "android": the plain "android" client now requires a GVS
# PO token (which a flagged host can't always mint -> the bot wall), while "android_vr" does not.
# A cookie-authenticated deployment should leave this unset.
# TUBEVAULT_YTDLP_PLAYER_CLIENT=android_vr

# --- Anti-flagging: pace yt-dlp so a residential IP isn't bot-walled ------------
# Gentle throttling is ON by default; the values below are the defaults — uncomment to tune.
# The bot wall is driven by request VOLUME + PATTERN, so slowing down is the biggest FREE lever.
# Crank these UP for a large back-catalog backfill (e.g. SLEEP_INTERVAL=30 / MAX=90); set a sleep
# to 0 to disable it.
# TUBEVAULT_YTDLP_SLEEP_REQUESTS=1            # seconds between metadata/extraction requests
# TUBEVAULT_YTDLP_SLEEP_INTERVAL=2           # min seconds before each download (randomized to MAX)
# TUBEVAULT_YTDLP_MAX_SLEEP_INTERVAL=5       # max of the randomized pre-download sleep
# TUBEVAULT_YTDLP_RETRIES=3                  # HTTP retries (tamed from yt-dlp's default 10)
# TUBEVAULT_YTDLP_FRAGMENT_RETRIES=5         # per-fragment retries (tamed from 10)
# TUBEVAULT_YTDLP_LIMIT_RATE=               # download cap, e.g. 2M or 500K (unset = uncapped)
# TUBEVAULT_YTDLP_CONCURRENT_FRAGMENTS=     # parallel fragments (unset = yt-dlp's safe 1; high = a trigger)
# (Download concurrency is NOT env anymore — it lives in Settings on the web UI,
#  clamped 1..4, default 1 = gentlest on the bot wall.)

# yt-dlp outbound proxy. Leave unset for a direct connection from this host's IP. If the host's
# OWN IP is bot-flagged by YouTube (the player_client dodge stops helping, and cookies trip the
# PO-token wall), route every yt-dlp request through a clean egress IP instead. Accepts an
# http(s):// or socks5:// URL. Unlike player_client, a proxy is compatible with cookie auth, so
# it is what unblocks members-only / age-gated archiving from a flagged host.
# TUBEVAULT_YTDLP_PROXY=socks5://10.0.0.2:1080

# Optional self-hosted bgutil PO-token provider. Leave unset and TubeVault works fine (the
# cookieless default clients need no PO token). To harden extraction against YouTube's PO-token
# enforcement, start the provider container and point yt-dlp at it: set the URL below AND bring
# the stack up with the `pot` profile:  docker compose --profile pot up -d
# TUBEVAULT_YTDLP_POT_PROVIDER_URL=http://bgutil-provider:4416

# Owner-session (membership / age-gated archiving): mount a 32-byte base64 key file read-only
# in docker-compose.yml (x-app-volumes) and uncomment TUBEVAULT_CREDENTIAL_KEY_FILE there —
# on the api AND both workers. Generate the key:  openssl rand -base64 32 > tubevault.key

# --- ADVANCED: worker scheduler cadence (rarely needed) -------------------------
# The archive worker's background sweeps. All have sane code defaults (shown);
# uncomment only to tune. Time values are milliseconds.
# TUBEVAULT_YTDLP_* pacing (above) is the usual bot-wall lever — reach for these
# only for a very large channel list or unusual re-check needs.
#
# Re-enumeration: rescan each registered channel's uploads for new videos.
# REENUMERATE_EVERY_MS=21600000        # 6h between sweeps
# REENUMERATE_BATCH_LIMIT=50           # channels re-enumerated per tick
#
# Source re-check: detect when an archived video's YouTube original goes away.
# SOURCE_RECHECK_SCAN_EVERY_MS=300000  # 5m scan tick
# SOURCE_RECHECK_INTERVAL_MS=604800000 # re-check each video at most every 7d
# SOURCE_RECHECK_BATCH_LIMIT=50        # videos probed per tick
# SOURCE_RECHECK_STREAK_THRESHOLD=2    # consecutive gone-probes before confirming
# SOURCE_CHECK_CONCURRENCY=1           # parallel probes (clamped 1..4; 1 = gentlest)
#
# Completeness re-check: resolve AWAITING_VERIFY live captures against the VOD.
# COMPLETENESS_CHECK_SCAN_EVERY_MS=300000  # 5m scan tick
# COMPLETENESS_CHECK_BATCH_LIMIT=50        # captures resolved per tick

# --- ADVANCED: local image build identity ---------------------------------------
# Only read by `docker compose build` (build-arg), NOT by the running app. Unset
# = images self-report 0.0.0-dev. Release images are built by the public
# release.yml from the tag; you never set a real release number by hand here.
# APP_VERSION=0.0.0-dev
# GIT_SHA=unknown
# BUILT_AT=
