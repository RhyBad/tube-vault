# --- TubeVault example env (copy to .env). Compose auto-loads this for ${...} interpolation. ---

# =========================================================================
# REQUIRED secrets — set all three; `docker compose` refuses to start without them.
# =========================================================================
TUBEVAULT_ACCESS_SECRET_HASH=change-me     # argon2 hash of your dashboard secret
TUBEVAULT_SESSION_KEY=change-me            # session signing key, >= 32 chars
POSTGRES_PASSWORD=change-me                # postgres password

# --- infra defaults ---
TUBEVAULT_TAG=latest                       # image tag to pull: ghcr.io/rhybad/tubevault-*:<TAG>
TUBEVAULT_WEB_PORT=8080                     # host port for the web/nginx service (the ONLY published port)
TUBEVAULT_MEDIA_DIR=./data/media           # host media dir -> container /data (media nests at /data/media)
TUBEVAULT_DB_DIR=./data/db                 # host postgres dir -> /var/lib/postgresql/data
TUBEVAULT_REDIS_DIR=./data/redis           # host redis dir -> /data

# --- optional app config (empty = app default) ---
POSTGRES_USER=tubevault
POSTGRES_DB=tubevault
# TUBEVAULT_INSECURE_COOKIES=1             # only for local http (no TLS)
# TUBEVAULT_SYNC_EXTRACT_TIMEOUT_MS=       # ms; empty = app default
# --- opt-in credential feature (off by default; see docker-compose.yml anchors) ---
# provide a read-only key at ./secrets/tubevault.key and uncomment the two anchor lines

# --- optional yt-dlp passthrough levers (empty = app/yt-dlp default) ---
# TUBEVAULT_YTDLP_PLAYER_CLIENT=
# TUBEVAULT_YTDLP_POT_PROVIDER_URL=
# TUBEVAULT_YTDLP_PROXY=
# TUBEVAULT_YTDLP_SLEEP_REQUESTS=
# TUBEVAULT_YTDLP_SLEEP_INTERVAL=
# TUBEVAULT_YTDLP_MAX_SLEEP_INTERVAL=
# TUBEVAULT_YTDLP_LIMIT_RATE=
# TUBEVAULT_YTDLP_CONCURRENT_FRAGMENTS=
# TUBEVAULT_YTDLP_RETRIES=
# TUBEVAULT_YTDLP_FRAGMENT_RETRIES=
