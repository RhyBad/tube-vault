# --- TubeVault example env (copy to .env) --- adjust to match the upstream image's actual variables ---
TUBEVAULT_SECRET=change-me-long-random          # dashboard shared-secret gate
TUBEVAULT_CREDENTIAL_KEY_FILE=/data/keys/cred.key   # set to ENABLE the YouTube-credential feature (else disabled)
DATABASE_URL=postgresql://tubevault:change-me@postgres:5432/tubevault
REDIS_URL=redis://redis:6379
VAULT_ROOT=/data/media                           # where archived media is stored
DEFAULT_LOCALE=en                                # UI default language (community locales bundled)
# TUBEVAULT_INSECURE_COOKIES=1                    # only for local http (no TLS)
